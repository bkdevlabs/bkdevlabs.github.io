---
export interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props;
---

<article class="bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow p-6 h-full">
  <div class="flex flex-col h-full">
    <div class="text-4xl mb-4" role="img" aria-label={`${title} icon`}>
      {icon}
    </div>
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-gray-600 flex-grow mb-4">{description}</p>
    <a 
      href={href} 
      class="text-blue-600 hover:text-blue-800 font-medium inline-flex items-center"
      aria-label={`Learn more about ${title}`}
    >
      Learn more
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</article>