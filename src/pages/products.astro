---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const products = [
{
    name: 'Flowchart.dev',
    description: 'Flowchart.dev is a modern, web-based flowchart drawing application.',
    type: 'Open Source',
    tags: ['Javascript', 'HTML5', 'CSS3', 'Canvas'],
    status: 'Active',
    github: 'https://github.com/bkdevlabs/flowchart.dev',
    link: 'https://flowchart.dev'
  },
  {
    name: 'Tutorial.js',
    description: 'An open-source modern cms for creating interactive tutorials and guides for web applications',
    type: 'Open Source',
    tags: ['React', 'NodeJs', 'Markdown', 'CMS'],
    status: 'Coming Soon',
  },
  {
    name: 'Tutorial.dev',
    description: 'Hosting platform for interactive web tutorials and guides, built with tutorial.js.',
    type: 'SaaS',
    tags: ['tutorial.js', 'Web Hosting', 'SaaS'],
    status: 'Coming Soon',
    link: 'https://tutorial.dev'
  },
  {
    name: 'Walkthroughs.ai',
    description: 'An interactive platform for creating AI-driven walkthroughs and tutorials.',
    type: 'SaaS',
    tags: ['AI', 'Walkthroughs', 'Tutorials'],
    status: 'Coming Soon',
  },
];
---

<BaseLayout title="Products" description="Open source projects and SaaS solutions by BKDevLabs">
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-purple-50 to-white py-12">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Our Products & Projects
        </h1>
        <p class="text-xl text-gray-600">
          Building tools and solutions that empower developers and businesses worldwide.
        </p>
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="py-16" aria-labelledby="products-heading">
    <div class="container mx-auto px-4">
      <h2 id="products-heading" class="sr-only">Products List</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {products.map((product) => (
          <article class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow overflow-hidden">
            <div class="p-6">
              <div class="flex items-start justify-between mb-4">
                <h3 class="text-2xl font-bold">{product.name}</h3>
                <span class={`px-3 py-1 rounded-full text-sm font-medium ${
                  product.status === 'Active' ? 'bg-green-100 text-green-700' :
                  product.status === 'Beta' ? 'bg-yellow-100 text-yellow-700' :
                  'bg-gray-100 text-gray-700'
                }`}>
                  {product.status}
                </span>
              </div>
              
              <p class="text-gray-600 mb-4">{product.description}</p>
              
              <div class="flex items-center justify-between mb-4">
                <span class={`text-sm font-medium ${
                  product.type === 'Open Source' ? 'text-blue-600' : 'text-purple-600'
                }`}>
                  {product.type}
                </span>
                <div class="flex gap-2">
                  {product.tags.map((tag) => (
                    <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              
<div class="pt-4 border-t flex gap-4">
  {product.github && (
    <a 
      href={product.github} 
      class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium"
      aria-label={`View ${product.name} on GitHub`}
    >
      <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      View on GitHub
    </a>
  )}
  {product.link && product.status !== 'Coming Soon' && (
    <a 
      href={product.link} 
      class="inline-flex items-center text-purple-600 hover:text-purple-800 font-medium"
      aria-label={`Visit ${product.name} website`}
    >
      Visit Website
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
    </a>
  )}
  {!product.github && (!product.link || product.status === 'Coming Soon') && (
    <span class="text-gray-500">Coming Soon</span>
  )}
</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source CTA -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Contribute to Open Source</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Join our community of developers building amazing tools together. 
        All our open source projects welcome contributions!
      </p>
      <Button href="https://github.com/bkdevlabs" variant="secondary">
        View All Projects on GitHub
      </Button>
    </div>
  </section>
</BaseLayout>