---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2" aria-label="BKDevLabs Home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" class="h-10 w-auto">
          <defs>
            <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#3B82F6;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:1" />
            </linearGradient>
          </defs>
          <g transform="translate(10, 15)">
            <path d="M 15 0 L 5 0 Q 0 0 0 5 L 0 25 Q 0 30 5 30 L 15 30" 
                  fill="none" 
                  stroke="url(#gradient)" 
                  stroke-width="3" 
                  stroke-linecap="round"/>
            <path d="M 25 0 L 35 0 Q 40 0 40 5 L 40 25 Q 40 30 35 30 L 25 30" 
                  fill="none" 
                  stroke="url(#gradient)" 
                  stroke-width="3" 
                  stroke-linecap="round"/>
            <path d="M 15 20 L 25 10" 
                  fill="none" 
                  stroke="url(#gradient)" 
                  stroke-width="3" 
                  stroke-linecap="round"/>
          </g>
          <text x="60" y="35" font-family="Arial, sans-serif" font-size="24" font-weight="700" fill="#1F2937">
            BKDev<tspan fill="url(#gradient)">Labs</tspan>
          </text>
        </svg>
      </a>

      <!-- Desktop Navigation -->
      <Navigation />

      <!-- Mobile Menu Button -->
      <MobileMenu />
    </div>
  </div>
</header>